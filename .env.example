# =============================================================
#  ECHO — Variables d'environnement
#  Copie ce fichier en ".env.local" puis remplis chaque valeur.
# =============================================================

# --- Clerk (authentification : inscription / connexion) ---
# Où : https://dashboard.clerk.com -> crée une application -> onglet "API Keys"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# --- Supabase (base de données PostgreSQL) ---
# Où : https://supabase.com/dashboard -> ton projet -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
# Clé "service_role" (SECRÈTE, jamais exposée au navigateur, usage serveur uniquement)
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- Anthropic (génération de texte : idées + rédaction des posts) ---
# Où : https://console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Stripe (abonnements) ---
# Où : https://dashboard.stripe.com/apikeys (clés API) et
#      https://dashboard.stripe.com/webhooks (signing secret du webhook)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price ID du plan Pro (créé dans Stripe -> Produits)
STRIPE_PRICE_PRO=price_xxx
# Même valeur que STRIPE_PRICE_PRO, exposée au client pour le bouton de paiement
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxx

# --- Upstash Redis (rate limiting des appels IA) ---
# Où : https://console.upstash.com -> Create Database (Redis) -> onglet "REST API"
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
